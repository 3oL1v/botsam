{
  "$schema": "https://schema.freqtrade.io/schema.json",
  "bot_name": "binance_futures_dry_bot",
  "initial_state": "running",
  "max_open_trades": 3,
  "stake_currency": "USDT",
  "stake_amount": "unlimited",
  "tradable_balance_ratio": 0.99,
  "fiat_display_currency": "USD",
  "dry_run": true,
  "dry_run_wallet": 100,
  "db_url": "sqlite:///tradesv3.binance_futures_dryrun.sqlite",
  "cancel_open_orders_on_exit": false,
  "force_entry_enable": true,
  "trading_mode": "futures",
  "margin_mode": "cross",
  "timeframe": "15m",
  "liquidation_buffer": 0.1,
  "unfilledtimeout": {
    "entry": 10,
    "exit": 10,
    "exit_timeout_count": 0,
    "unit": "minutes"
  },
  "entry_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1,
    "price_last_balance": 0.0,
    "check_depth_of_market": {
      "enabled": false,
      "bids_to_ask_delta": 1
    }
  },
  "exit_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1
  },
  "order_types": {
    "entry": "limit",
    "exit": "limit",
    "emergency_exit": "market",
    "stoploss": "market",
    "stoploss_on_exchange": true,
    "stoploss_on_exchange_interval": 60
  },
  "exchange": {
    "name": "binance",
    "key": "",
    "secret": "",
    "ccxt_config": {
      "enableRateLimit": true,
      "options": {
        "defaultType": "swap"
      }
    },
    "ccxt_async_config": {
      "enableRateLimit": true,
      "options": {
        "defaultType": "swap"
      }
    },
    "pair_whitelist": [
      "BTC/USDT:USDT",
      "ETH/USDT:USDT",
      "SOL/USDT:USDT"
    ],
    "pair_blacklist": []
  },
  "pairlists": [
    {
      "method": "StaticPairList"
    }
  ],
  "telegram": {
    "enabled": true,
    "token": "",
    "chat_id": "",
    "allow_custom_messages": true,
    "notification_settings": {
      "status": "silent",
      "warning": "on",
      "startup": "on",
      "entry": "off",
      "entry_fill": "off",
      "entry_cancel": "off",
      "exit": {
        "roi": "off",
        "emergency_exit": "off",
        "force_exit": "off",
        "exit_signal": "off",
        "trailing_stop_loss": "off",
        "stop_loss": "off",
        "stoploss_on_exchange": "off",
        "custom_exit": "off",
        "liquidation": "off",
        "partial_exit": "off",
        "*": "off"
      },
      "exit_cancel": "off",
      "exit_fill": "off",
      "strategy_msg": "on",
      "protection_trigger": "on",
      "protection_trigger_global": "on"
    }
  },
  "api_server": {
    "enabled": true,
    "listen_ip_address": "127.0.0.1",
    "listen_port": 8081,
    "verbosity": "error",
    "enable_openapi": false,
    "jwt_secret_key": "LOCAL_INTERNAL_ONLY_change_via_env_FREQTRADE__API_SERVER__JWT_SECRET_KEY",
    "ws_token": "LOCAL_INTERNAL_ONLY_change_via_env",
    "CORS_origins": [],
    "username": "freqtrader",
    "password": "LOCAL_INTERNAL_ONLY_change_via_env"
  },
  "internals": {
    "process_throttle_secs": 5
  },
  "dataformat_ohlcv": "feather"
}